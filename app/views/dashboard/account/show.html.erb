<div class="page-header">
  <h1 class="page-title">Account</h1>
</div>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">API Key</h2>
  </div>
  <div class="card-body">
    <% if @new_api_key.present? %>
      <p class="alert alert-success">Copy your new API key below. It won't be shown again.</p>
      <div class="api-key-copy-wrap" id="api-key-copy-wrap" data-api-key="<%= @new_api_key %>">
        <button type="button" class="api-key-copy-btn" id="api-key-copy-btn" title="Copy" aria-label="Copy API key">
          <svg class="api-key-copy-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <svg class="api-key-check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </button>
        <span class="api-key-copy-feedback clipboard-feedback-hidden" id="api-key-copy-feedback" aria-live="polite"></span>
        <pre class="api-key-display"><code><%= @new_api_key %></code></pre>
      </div>
      <script>
        (function() {
          var wrap = document.getElementById('api-key-copy-wrap');
          var btn = document.getElementById('api-key-copy-btn');
          var feedback = document.getElementById('api-key-copy-feedback');
          if (!wrap || !btn) return;
          function getText() {
            var code = wrap.querySelector('code');
            return code ? (code.textContent || '').trim() : (wrap.getAttribute('data-api-key') || '').trim();
          }
          function showSuccess() {
            btn.classList.add('is-copied');
            btn.setAttribute('aria-label', 'Copied');
            setTimeout(function() {
              btn.classList.remove('is-copied');
              btn.setAttribute('aria-label', 'Copy API key');
            }, 1200);
          }
          function showFailure() {
            if (feedback) {
              feedback.textContent = 'Copy failed';
              feedback.classList.remove('clipboard-feedback-hidden');
              feedback.classList.add('clipboard-feedback-error');
              setTimeout(function() {
                feedback.textContent = '';
                feedback.classList.add('clipboard-feedback-hidden');
                feedback.classList.remove('clipboard-feedback-error');
              }, 1500);
            }
          }
          function fallbackCopy(text) {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.setAttribute('readonly', '');
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            try {
              var ok = document.execCommand('copy');
              document.body.removeChild(ta);
              if (ok) showSuccess(); else showFailure();
            } catch (e) {
              document.body.removeChild(ta);
              showFailure();
            }
          }
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var text = getText();
            if (!text) { showFailure(); return; }
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(text).then(showSuccess).catch(function() { fallbackCopy(text); });
            } else {
              fallbackCopy(text);
            }
          });
        })();
      </script>
    <% else %>
      <p class="text-muted">API keys are not displayed after creation. If you forgot your key, regenerate a new one below. The old key will stop working.</p>
    <% end %>

    <%= button_to "Regenerate API key", dashboard_regenerate_api_key_path, method: :post, class: "btn btn-secondary", data: { turbo_confirm: "This will invalidate your current API key. Continue?" } %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">Email &amp; password</h2>
  </div>
  <div class="card-body">
    <% if current_merchant.email.present? %>
      <p class="text-muted">You can sign in with <strong><%= current_merchant.email %></strong>. Update below if needed.</p>
    <% else %>
      <p class="text-muted">Set email and password so you can sign in without your API key (e.g. if you forget it).</p>
    <% end %>

    <%= form_with url: dashboard_update_credentials_path, scope: :merchant, method: :patch, local: true, class: "form-inline-block" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-input", value: current_merchant.email, placeholder: "you@example.com", autocomplete: "email" %>
      </div>
      <div class="form-group">
        <%= f.label :password, "Password (leave blank to keep current)", class: "form-label" %>
        <%= f.password_field :password, class: "form-input", placeholder: "••••••••", autocomplete: "new-password" %>
      </div>
      <%= f.submit "Save", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
